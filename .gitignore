# Kiro skill artifacts (code-review, refactor, steering-maintenance, judgement)
**/.code-review/
**/.judgement/
**/.refactor/
**/.steering-maintenance/

# Python bytecode cache (e.g. from running _ci_local.py / scripts locally)
__pycache__/
*.pyc

# Runtime-generated sync manifest. classify-repos.py emits this fresh on every
# sync.yaml run (and feeds it straight to repo-file-sync-action), so it is never
# committed; a committed copy only drifts against the live repo set.
.github/sync.yml
